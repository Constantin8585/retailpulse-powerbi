/// Référentiel client. Contient des données personnelles (PII).
table DimCustomer
	lineageTag: 2879d9a0-16b0-4739-b917-9517fb50f2a6

	measure 'Active Customers' = DISTINCTCOUNT(FactSales[CustomerKey])
		formatString: 0
		displayFolder: 03- Customer
		lineageTag: 66892bb6-e819-4ea7-8ab5-ce95b1b42aad

	measure 'Repeat Customers' =
			
			COUNTROWS(
			    FILTER(
			        VALUES(FactSales[CustomerKey]),
			        CALCULATE(DISTINCTCOUNT(FactSales[OrderKey])) > 1
			    )
			)
		formatString: 0
		displayFolder: 03- Customer
		lineageTag: ccf713f0-a480-45ff-ab32-96ec3cac863f

	measure 'Customer Retention Rate' = DIVIDE([Repeat Customers], [Active Customers])
		formatString: 0.00\ %;-0.00\ %;0.00\ %
		displayFolder: 03- Customer
		lineageTag: a27b0fdd-c17c-4013-8772-f02ebdb9b676

	column CustomerKey
		dataType: int64
		isHidden
		formatString: 0
		lineageTag: 8d5a6f57-52b5-4203-8c7a-13ee593e8c31
		summarizeBy: none
		sourceColumn: CustomerKey

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

